# ============================================================
# Grand Frère Intelligent – Variables d'environnement
# Renommer ce fichier en .env et remplir les valeurs réelles
# NE PAS COMMITTER le fichier .env dans Git
# ============================================================

# --- Base de données MySQL (Hostinger) ---
DB_HOST=localhost
DB_NAME=nom_de_votre_base
DB_USER=votre_utilisateur_mysql
DB_PASS=votre_mot_de_passe_mysql
DB_PORT=3306

# --- Sécurité JWT ---
# Générer une clé aléatoire sécurisée (ex: openssl rand -base64 64)
JWT_SECRET=VOTRE_CLE_JWT_SUPER_SECRETE_A_CHANGER
JWT_EXPIRY=86400

# --- URL de l'API IA (Google Colab via Cloudflare Tunnel) ---
# Cette URL change à chaque session Colab. Mettre à jour à chaque redémarrage.
IA_API_URL=https://VOTRE-URL-COLAB.trycloudflare.com

# --- Configuration Email (PHPMailer) ---
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USER=noreply@votredomaine.com
MAIL_PASS=votre_mot_de_passe_email
MAIL_FROM=noreply@votredomaine.com
MAIL_FROM_NAME="Grand Frère Intelligent"

# --- Orange SMS API (Orange Developer Burkina Faso) ---
# Obtenir sur https://developer.orange.com/
ORANGE_SMS_CLIENT_ID=VOTRE_CLIENT_ID_ORANGE
ORANGE_SMS_CLIENT_SECRET=VOTRE_CLIENT_SECRET_ORANGE
# Numéro expéditeur (formaté : tel:+22601000000)
ORANGE_SMS_SENDER=tel:+22601000000
# URL API Orange
ORANGE_SMS_TOKEN_URL=https://api.orange.com/oauth/v3/token
ORANGE_SMS_SEND_URL=https://api.orange.com/smsmessaging/v1/outbound

# --- Senfenico (Paiement Orange Money / Moov Money) ---
# Obtenir sur https://senfenico.com/
SENFENICO_SECRET_KEY=sk_live_VOTRE_CLE_SENFENICO
SENFENICO_PUBLIC_KEY=pk_live_VOTRE_CLE_PUBLIQUE_SENFENICO
SENFENICO_API_URL=https://api.senfenico.com/v1
# URL de succès après paiement (retour WebView Flutter)
SENFENICO_SUCCESS_URL=https://votredomaine.com/payment_success.html
SENFENICO_CANCEL_URL=https://votredomaine.com/payment_cancel.html
# URL publique de votre API pour les webhooks Senfenico
SENFENICO_WEBHOOK_SECRET=VOTRE_SECRET_WEBHOOK_SENFENICO

# --- Firebase Cloud Messaging (FCM) ---
FCM_SERVER_KEY=VOTRE_CLE_SERVEUR_FCM
FCM_PROJECT_ID=votre-projet-firebase

# --- Application ---
APP_URL=https://votredomaine.com/api
APP_ENV=production
APP_DEBUG=false
UPLOAD_DIR=/home/user/public_html/uploads/
MAX_FILE_SIZE=5242880

# --- Rate Limiting ---
RATE_LIMIT_FREE=50
RATE_LIMIT_PREMIUM=200
