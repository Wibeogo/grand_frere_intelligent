{
    "name": "grand-frere/api",
    "description": "API REST pour l'application Grand Frère Intelligent",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "vlucas/phpdotenv": "^5.6",
        "phpmailer/phpmailer": "^6.9",
        "guzzlehttp/guzzle": "^7.8",
        "firebase/php-jwt": "^6.10"
    },
    "autoload": {
        "psr-4": {
            "GrandFrere\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "audit": {
            "ignore": ["PKSA-y2cr-5h3j-g3ys"]
        }
    }
}
